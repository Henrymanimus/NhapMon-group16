# =============================================
# Backend Environment Variables — copy to .env
# =============================================

# Server
NODE_ENV=development
PORT=4000

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=8h

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=rental_house_management

# Cho phép đăng nhập bằng mật khẩu plaintext (chỉ dùng khi seed demo)
AUTH_ALLOW_PLAINTEXT_FALLBACK=false
