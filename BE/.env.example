# =============================================
# Backend Environment Variables — copy to .env
# =============================================

# Server
NODE_ENV=development
PORT=4000

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=8h

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=rental_house_management

# Cho phép đăng nhập bằng mật khẩu plaintext (chỉ dùng khi seed demo)
AUTH_ALLOW_PLAINTEXT_FALLBACK=false

# Email SMTP for forgot-password OTP
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_gmail_address@gmail.com
# SMTP_PASS=your_16_character_app_password
# SMTP_FROM="Nha Tro Pro <your_gmail_address@gmail.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
